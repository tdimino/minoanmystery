<script>
  function initServiceAnimations() {
    // Move slotted components into their markdown placeholder positions
    document.querySelectorAll('[data-slot-source]').forEach((source) => {
      const targetId = source.getAttribute('data-slot-source');
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (target) {
        // Move all children from the source wrapper into the placeholder
        while (source.firstChild) {
          target.appendChild(source.firstChild);
        }
        source.remove();
      }
    });

    // General scroll reveals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '-50px 0px' }
    );

    document.querySelectorAll('.animate-on-scroll, .animate-scale-in, .fade-animate').forEach((el) => {
      observer.observe(el);
    });

    // Staggered H2 section reveals within rich-text
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('section-visible');
            sectionObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '-30px 0px' }
    );

    document.querySelectorAll('.rich-text h2, .rich-text figure[data-badge]').forEach((el) => {
      el.classList.add('section-reveal');
      sectionObserver.observe(el);
    });
  }

  // GlowBorder on related portfolio cards
  function initDetailGlow() {
    document.querySelectorAll('.related-card').forEach((card) => {
      card.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        (card as HTMLElement).style.setProperty('--glow-x', `${mouseEvent.clientX - rect.left}px`);
        (card as HTMLElement).style.setProperty('--glow-y', `${mouseEvent.clientY - rect.top}px`);
      });
    });
  }

  initServiceAnimations();
  initDetailGlow();
  document.addEventListener('astro:after-swap', () => {
    initServiceAnimations();
    initDetailGlow();
  });
</script>

