<script>
  function initServicesAnimations() {
    // General elements: observe normally
    const generalObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            generalObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '-50px 0px' }
    );

    document.querySelectorAll('.animate-on-scroll, .fade-animate, .collage-frame').forEach((el) => {
      generalObserver.observe(el);
    });

    // Service entries: staggered cascade (120ms between each)
    const serviceObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt((entry.target as HTMLElement).dataset.index || '0', 10);
            setTimeout(() => {
              entry.target.classList.add('is-visible');
            }, index * 120);
            serviceObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: '-20px 0px' }
    );

    document.querySelectorAll('.service-entry').forEach((el, i) => {
      (el as HTMLElement).dataset.index = String(i);
      serviceObserver.observe(el);
    });
  }

  // GlowBorder: mouse-tracking radial gradient
  function initGlowBorder() {
    document.querySelectorAll('.service-entry').forEach((card) => {
      card.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        (card as HTMLElement).style.setProperty('--glow-x', `${mouseEvent.clientX - rect.left}px`);
        (card as HTMLElement).style.setProperty('--glow-y', `${mouseEvent.clientY - rect.top}px`);
      });
    });
  }

  // Collage Gallery: CSS 3D parallax tilt
  function initCollageTilt() {
    const gallery = document.querySelector('.collage-gallery');
    if (!gallery || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const frames = gallery.querySelectorAll('.collage-frame');
    const MAX_TILT = 8;

    gallery.addEventListener('mousemove', (e) => {
      frames.forEach((frame) => {
        const rect = frame.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const dx = Math.max(-1, Math.min(1, (e.clientX - centerX) / (rect.width / 2)));
        const dy = Math.max(-1, Math.min(1, (e.clientY - centerY) / (rect.height / 2)));
        const dist = Math.sqrt(Math.pow(e.clientX - centerX, 2) + Math.pow(e.clientY - centerY, 2));
        const proximity = Math.max(0, 1 - dist / (rect.width * 1.5));
        const tiltX = dy * MAX_TILT * proximity * -1;
        const tiltY = dx * MAX_TILT * proximity;
        (frame as HTMLElement).style.transform = `perspective(1200px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
      });
    });

    gallery.addEventListener('mouseleave', () => {
      frames.forEach((frame) => {
        (frame as HTMLElement).style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg)';
        (frame as HTMLElement).style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
        setTimeout(() => {
          (frame as HTMLElement).style.transition = '';
        }, 600);
      });
    });
  }

  // Collage Modal
  function initCollageModal() {
    const modal = document.getElementById('collage-modal') as HTMLDialogElement;
    if (!modal) return;

    const collageData = JSON.parse(document.getElementById('collage-data')?.textContent || '[]');
    let currentIndex = 0;

    function showCollage(index: number) {
      currentIndex = index;
      const c = collageData[index];
      (document.getElementById('modal-img') as HTMLImageElement).src = c.src;
      (document.getElementById('modal-img') as HTMLImageElement).alt = c.title;
      document.getElementById('modal-title')!.textContent = c.title;
      document.getElementById('modal-subtitle')!.textContent = c.subtitle;
      document.getElementById('modal-description')!.textContent = c.description;
      document.getElementById('poem-title')!.textContent = c.poemTitle;
      document.getElementById('poem-subtitle')!.textContent = c.poemSubtitle;
      document.getElementById('poem-text')!.innerHTML = c.poem;
    }

    // Click handlers on collage frames
    document.querySelectorAll('.collage-frame').forEach((frame, i) => {
      frame.addEventListener('click', () => {
        showCollage(i);
        modal.showModal();
      });
    });

    // Navigation
    modal.querySelector('.modal-prev')?.addEventListener('click', () => {
      showCollage((currentIndex - 1 + collageData.length) % collageData.length);
    });
    modal.querySelector('.modal-next')?.addEventListener('click', () => {
      showCollage((currentIndex + 1) % collageData.length);
    });

    // Close
    modal.querySelector('.modal-close')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    // Keyboard
    modal.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') showCollage((currentIndex - 1 + collageData.length) % collageData.length);
      if (e.key === 'ArrowRight') showCollage((currentIndex + 1) % collageData.length);
    });
  }

  initServicesAnimations();
  initCollageTilt();
  initGlowBorder();
  initCollageModal();
  document.addEventListener('astro:after-swap', () => {
    initServicesAnimations();
    initCollageTilt();
    initGlowBorder();
    initCollageModal();
  });
</script>
