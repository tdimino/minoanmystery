---
import { ViewTransitions } from 'astro:transitions';
import ThemeScript from '../components/ThemeScript.astro';
import CommandPalette from '../components/CommandPalette.astro';
import SoulHint from '../components/SoulHint.astro';
import FloatingDialogue from '../components/FloatingDialogue.astro';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "The human language system remains the most potent magic known to us. At Minoan Mystery, I dig to the root of what you do, and make it more powerful with words.",
  image = "/images/og/default.png"
} = Astro.props;

// Ensure canonical URL never has trailing slash (except root) for consistency
const pathname = Astro.url.pathname === '/'
  ? '/'
  : Astro.url.pathname.replace(/\/$/, '');
const canonicalURL = new URL(pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="generator" content={Astro.generator}>

  <!-- Theme Script - MUST be before styles to prevent FOUC -->
  <ThemeScript />

  <!-- Primary Meta Tags -->
  <title>{title} | Minoan Mystery</title>
  <meta name="title" content={`${title} | Minoan Mystery`}>
  <meta name="description" content={description}>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL}>

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={`${title} | Minoan Mystery`}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(image, Astro.site)}>

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content={canonicalURL}>
  <meta property="twitter:title" content={`${title} | Minoan Mystery`}>
  <meta property="twitter:description" content={description}>
  <meta property="twitter:image" content={new URL(image, Astro.site)}>

  <!-- Site-wide Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://www.minoanmystery.org/#website",
        "name": "Minoan Mystery",
        "url": "https://www.minoanmystery.org",
        "description": "Tom di Mino — AI/ML engineer, GEO/SEO consultant, and builder of cognitive systems. Services for startups and businesses navigating A.I.",
        "publisher": { "@id": "https://www.minoanmystery.org/#person" }
      },
      {
        "@type": "Person",
        "@id": "https://www.minoanmystery.org/#person",
        "name": "Tom di Mino",
        "url": "https://www.minoanmystery.org",
        "jobTitle": "Principal AI/ML Engineer",
        "sameAs": [
          "https://github.com/tdimino",
          "https://x.com/IdaeanDaktyl",
          "https://tomdimino.substack.com",
          "https://www.linkedin.com/in/tomdimino"
        ]
      }
    ]
  })} />

  <!-- Sunny mode credit — technique by @danywander (dany.works) -->
  <meta name="credits" content="Sunny mode technique by @danywander (dany.works)">

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/favicon.ico">

  <!-- Preload critical fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Page-specific head content -->
  <slot name="head" />

  <!-- View Transitions for smooth page navigation -->
  <ViewTransitions />

  <!-- Persist theme across View Transitions -->
  <script is:inline>
    document.addEventListener('astro:before-swap', (event) => {
      // Transfer theme from current document to new document
      const currentTheme = document.documentElement.getAttribute('data-theme');
      if (currentTheme) {
        event.newDocument.documentElement.setAttribute('data-theme', currentTheme);
      }
    });
  </script>
</head>
<body>
  <!-- Sunny mode — dappled leaf shadows (hidden unless data-theme="sunny") -->
  <video
    class="sunny-shadows"
    src="/leaves.mp4"
    loop
    muted
    playsinline
    preload="none"
    aria-hidden="true"
    id="sunny-shadows-video"
  ></video>

  <div class="page-wrapper">
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </div>

  <!-- Theme ambient audio -->
  <audio id="sunny-audio" src="/forest.mp3" loop preload="none" aria-hidden="true"></audio>
  <audio id="night-audio" src="/night.mp3" loop preload="none" aria-hidden="true"></audio>

  <!-- Sunny shadows video + theme ambient audio controller -->
  <script is:inline>
    (function() {
      var _themeObs = null;
      var _prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function stopAudio(el) {
        if (el) { el.pause(); el.currentTime = 0; }
      }

      function playAudio(el) {
        if (el && !_prefersReduced) { el.volume = 0.3; el.play().catch(function(){}); }
      }

      function applyTheme(theme) {
        var video = document.getElementById('sunny-shadows-video');
        var sunnyAudio = document.getElementById('sunny-audio');
        var nightAudio = document.getElementById('night-audio');

        // Video: sunny only
        if (theme === 'sunny') { if (video) video.play().catch(function(){}); }
        else { if (video) { video.pause(); video.currentTime = 0; } }

        // Audio: sunny → forest, dark → crickets, light → silence
        stopAudio(sunnyAudio);
        stopAudio(nightAudio);
        if (theme === 'sunny') playAudio(sunnyAudio);
        else if (theme === 'dark') playAudio(nightAudio);
      }

      function initThemeMedia() {
        if (_themeObs) { _themeObs.disconnect(); _themeObs = null; }
        _themeObs = new MutationObserver(function() {
          applyTheme(document.documentElement.getAttribute('data-theme') || 'light');
        });
        _themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

        // Init video (muted — always allowed), but defer audio to first gesture
        var theme = document.documentElement.getAttribute('data-theme') || 'light';
        if (theme === 'sunny') {
          var video = document.getElementById('sunny-shadows-video');
          if (video) video.play().catch(function(){});
        }
        // Audio deferred: browser blocks autoplay without gesture.
        // The MutationObserver fires from the theme toggle click (user gesture),
        // so audio starts naturally when the user actually toggles the theme.
      }

      // Teardown before View Transition swap
      document.addEventListener('astro:before-swap', function() {
        stopAudio(document.getElementById('sunny-audio'));
        stopAudio(document.getElementById('night-audio'));
        var video = document.getElementById('sunny-shadows-video');
        if (video) { video.pause(); }
        if (_themeObs) { _themeObs.disconnect(); _themeObs = null; }
      });

      initThemeMedia();
      document.addEventListener('astro:after-swap', initThemeMedia);
    })();
  </script>

  <!-- Motion for scroll animations -->
  <script>
    import { animate, scroll, stagger, inView } from 'motion';

    // Initialize animations after DOM is ready
    function initAnimations() {
      // Skew animations - animate when scrolled into view
      document.querySelectorAll('.skew-animate').forEach((el) => {
        // Set initial state
        el.style.opacity = '0';
        el.style.transform = 'translateY(36%) skew(-6deg, -1deg)';

        inView(el, () => {
          animate(el, {
            opacity: 1,
            transform: 'translateY(0) skew(0deg, 0deg)'
          }, {
            duration: 0.8,
            easing: [0.25, 0.46, 0.45, 0.94] // power2.out equivalent
          });
        }, { margin: '-15% 0px' });
      });

      // Scale animations
      document.querySelectorAll('.scale-animate').forEach((el) => {
        el.style.opacity = '0';
        el.style.transform = 'scale(0.97)';

        inView(el, () => {
          animate(el, {
            opacity: 1,
            transform: 'scale(1)'
          }, {
            duration: 0.6,
            easing: [0.25, 0.46, 0.45, 0.94]
          });
        }, { margin: '-15% 0px' });
      });

      // Fade animations
      document.querySelectorAll('.fade-animate').forEach((el) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';

        inView(el, () => {
          animate(el, {
            opacity: 1,
            transform: 'translateY(0)'
          }, {
            duration: 0.6,
            easing: [0.25, 0.46, 0.45, 0.94]
          });
        }, { margin: '-15% 0px' });
      });

      // Image reveal animations
      document.querySelectorAll('.image-reveal').forEach((el) => {
        const overlay = el.querySelector('.reveal-overlay');
        if (overlay) {
          inView(el, () => {
            animate(overlay, {
              width: '0%'
            }, {
              duration: 0.8,
              easing: [0.45, 0, 0.55, 1] // power2.inOut equivalent
            });
          }, { margin: '-20% 0px' });
        }
      });

      // Stagger animations for lists
      document.querySelectorAll('[data-stagger]').forEach((container) => {
        const items = Array.from(container.children);
        items.forEach((item) => {
          item.style.opacity = '0';
          item.style.transform = 'translateY(30px)';
        });

        inView(container, () => {
          animate(items, {
            opacity: 1,
            transform: 'translateY(0)'
          }, {
            duration: 0.5,
            delay: stagger(0.1),
            easing: [0.25, 0.46, 0.45, 0.94]
          });
        }, { margin: '-15% 0px' });
      });
    }

    // Run on initial load
    initAnimations();

    // Re-run after view transitions
    document.addEventListener('astro:after-swap', initAnimations);
  </script>

  <!-- Command Palette - Global keyboard shortcut -->
  <CommandPalette />

  <!-- Soul Engine Components -->
  <SoulHint />
  <FloatingDialogue />

  <!-- Soul Engine Initialization -->
  <script>
    import { initSoul, getSoul, setupViewTransitions } from '../lib/soul';

    // Initialize soul engine
    function initSoulEngine() {
      try {
        initSoul();
        setupViewTransitions();
      } catch (e) {
        console.warn('[Soul] Initialization failed:', e);
      }
    }

    // Run on initial load
    initSoulEngine();

    // Re-initialize after view transitions
    document.addEventListener('astro:after-swap', () => {
      // Soul persists across transitions, just re-evaluate
      try {
        const soul = getSoul();
        if (soul) {
          soul.processes.evaluate();
          soul.triggers.evaluate();
        } else {
          initSoulEngine();
        }
      } catch (e) {
        // Fallback: reinitialize
        initSoulEngine();
      }
    });
  </script>
</body>
</html>
