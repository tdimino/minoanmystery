---
/**
 * LiveProofDashboard — Dual-site ranking dashboard for GEO/SEO proof section.
 * Side-by-side: worldwarwatcher.com (teal) + minoanmystery.org (Tyrian purple).
 * 2x2 ranking grid per column with animated countdown counters.
 * Replaces ProofCard.
 */
const sites = [
  {
    name: 'worldwarwatcher.com',
    url: 'https://worldwarwatcher.com',
    color: '#2dd4bf',
    badge: null,
    rankings: [
      { platform: 'Google', rank: 1, label: '#1', verifyUrl: 'https://www.google.com/search?q=World+War+Watcher' },
      { platform: 'Bing', rank: 1, label: '#1', verifyUrl: 'https://www.bing.com/search?q=World+War+Watcher' },
      { platform: 'Perplexity', rank: 0, label: 'Cited', verifyUrl: 'https://www.perplexity.ai/search?q=World+War+Watcher' },
      { platform: 'ChatGPT', rank: 0, label: 'Cited', verifyUrl: null },
    ],
  },
  {
    name: 'minoanmystery.org',
    url: 'https://minoanmystery.org',
    color: '#9b59b6',
    badge: 'This site',
    rankings: [
      { platform: 'Google', rank: 8, label: '#8', verifyUrl: 'https://www.google.com/search?q=minoanmystery.org' },
      { platform: 'Bing', rank: 3, label: '#3', verifyUrl: 'https://www.bing.com/search?q=minoanmystery.org' },
      { platform: 'Perplexity', rank: 0, label: 'Cited', verifyUrl: 'https://www.perplexity.ai/search?q=minoanmystery.org' },
      { platform: 'Claude', rank: 0, label: 'Cited', verifyUrl: null },
    ],
  },
];
---

<div class="live-proof" aria-label="Ranking proof: two sites built with these GEO/SEO techniques">
  <div class="lp-header">
    <span class="lp-title">Live Rankings</span>
    <span class="lp-badge">Verified</span>
  </div>

  <div class="lp-columns">
    {sites.map((site) => (
      <div class="lp-column" style={`--site-color: ${site.color}`}>
        <div class="lp-site-header">
          <a href={site.url} target="_blank" rel="noopener noreferrer" class="lp-site-name">{site.name}</a>
          {site.badge && <span class="lp-this-site">{site.badge}</span>}
        </div>
        <div class="lp-rankings">
          {site.rankings.map((r) => (
            r.verifyUrl ? (
              <a href={r.verifyUrl} target="_blank" rel="noopener noreferrer" class="lp-rank-card lp-rank-link">
                <span class="lp-rank-platform">{r.platform}</span>
                <span class="lp-rank-value" data-target={r.rank > 0 ? r.rank : ''}>
                  {r.rank > 0 ? `#${r.rank}` : r.label}
                </span>
                <span class="lp-verify">verify &rarr;</span>
              </a>
            ) : (
              <div class="lp-rank-card">
                <span class="lp-rank-platform">{r.platform}</span>
                <span class="lp-rank-value" data-target={r.rank > 0 ? r.rank : ''}>
                  {r.rank > 0 ? `#${r.rank}` : r.label}
                </span>
              </div>
            )
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="lp-scanline" aria-hidden="true"></div>
</div>

<style>
  .live-proof {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
    background: #0d0d0d;
    position: relative;
  }

  .lp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid #1a1a1a;
  }

  .lp-title {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #e0e0e0;
  }

  .lp-badge {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: 100px;
    background: rgba(45, 212, 127, 0.15);
    color: #2dd47f;
  }

  .lp-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .lp-column {
    padding: 20px;
    border-right: 1px solid #1a1a1a;
  }

  .lp-column:last-child { border-right: none; }

  .lp-site-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .lp-site-name {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--site-color);
    text-decoration: none;
    border-bottom: 1px dashed var(--site-color);
    transition: opacity 0.2s ease;
  }

  .lp-site-name:hover {
    opacity: 0.8;
    color: var(--site-color);
  }

  .lp-this-site {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 6px;
    border-radius: 3px;
    background: rgba(155, 89, 182, 0.15);
    color: #9b59b6;
  }

  .lp-rankings {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .lp-rank-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
    background: #161616;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    position: relative;
  }

  .lp-rank-link {
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .lp-rank-link:hover {
    border-color: var(--site-color);
  }

  .lp-rank-link:hover .lp-verify {
    opacity: 1;
  }

  .lp-verify {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    color: #666;
    opacity: 0;
    transition: opacity 0.2s ease;
    margin-top: 4px;
  }

  .lp-rank-platform {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .lp-rank-value {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    color: var(--site-color);
  }

  /* CRT scanline overlay */
  .lp-scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.05) 2px,
      rgba(0, 0, 0, 0.05) 4px
    );
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .lp-columns {
      grid-template-columns: 1fr;
    }
    .lp-column { border-right: none; border-bottom: 1px solid #1a1a1a; }
    .lp-column:last-child { border-bottom: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-rank-value { transition: none; }
  }

  @media (scripting: enabled) {
    .live-proof:not(.is-visible) {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .live-proof.is-visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
  }
</style>

<script>
  function initLiveProof() {
    document.querySelectorAll('.live-proof').forEach((el) => {
      let animated = false;

      function animateRanks() {
        if (animated) return;
        animated = true;
        el.querySelectorAll('.lp-rank-value[data-target]').forEach((val) => {
          const target = parseInt((val as HTMLElement).dataset.target || '0', 10);
          if (!target) return;
          let current = 50;
          const interval = setInterval(() => {
            current = Math.max(current - Math.ceil((current - target) / 4), target);
            val.textContent = `#${current}`;
            if (current <= target) {
              clearInterval(interval);
              val.textContent = `#${target}`;
            }
          }, 60);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animateRanks();
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(el);
      setTimeout(() => { if (!el.classList.contains('is-visible')) { el.classList.add('is-visible'); animateRanks(); } }, 2000);
    });
  }

  initLiveProof();
  document.addEventListener('astro:after-swap', initLiveProof);
</script>
