---
/**
 * LiveProofDashboard — Dual-site ranking + traffic dashboard for GEO/SEO proof section.
 * Orchestrator: imports proof-metrics.json + sub-components.
 *
 * Layout: asymmetric 55/45 columns (WWW gets more space), gold-bordered traffic
 * telemetry strip below rankings, inline SVG sparkline, social proof callout.
 *
 * Design system: minoanmystery.org tokens (Tyrian purple + gold), NOT PHOSPHOR VIGIL.
 */
import RankingGrid from './proof/RankingGrid.astro';
import TrafficMetrics from './proof/TrafficMetrics.astro';
import VerifyFooter from './proof/VerifyFooter.astro';
import type { ProofMetrics } from '../../types/proof';

let metrics: ProofMetrics;
try {
  const mod = await import('../../data/proof-metrics.json');
  metrics = (mod.default ?? mod) as ProofMetrics;
} catch {
  // Fallback: hardcoded rankings, no traffic
  metrics = {
    generated: new Date().toISOString(),
    sites: [
      {
        id: 'worldwarwatcher',
        name: 'worldwarwatcher.com',
        url: 'https://worldwarwatcher.com',
        color: '#2dd4bf',
        badge: null,
        rankings: [
          { platform: 'Google', rank: 1, label: '#1', verifyUrl: 'https://www.google.com/search?q=World+War+Watcher' },
          { platform: 'Bing', rank: 1, label: '#1', verifyUrl: 'https://www.bing.com/search?q=World+War+Watcher' },
          { platform: 'Perplexity', rank: 0, label: 'Cited', verifyUrl: 'https://www.perplexity.ai/search?q=World+War+Watcher' },
          { platform: 'ChatGPT', rank: 0, label: 'Cited', verifyUrl: null },
        ],
        traffic: null,
        socialProof: null,
      },
      {
        id: 'minoanmystery',
        name: 'minoanmystery.org',
        url: 'https://minoanmystery.org',
        color: '#9b59b6',
        badge: 'This site',
        rankings: [
          { platform: 'Google', rank: 8, label: '#8', verifyUrl: 'https://www.google.com/search?q=minoanmystery.org' },
          { platform: 'Bing', rank: 3, label: '#3', verifyUrl: 'https://www.bing.com/search?q=minoanmystery.org' },
          { platform: 'Perplexity', rank: 0, label: 'Cited', verifyUrl: 'https://www.perplexity.ai/search?q=minoanmystery.org' },
          { platform: 'Claude', rank: 0, label: 'Cited', verifyUrl: null },
        ],
        traffic: null,
        socialProof: null,
      },
    ],
  };
}

const verifiedDate = new Date(metrics.generated);
const verifiedFormatted = verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// Find the site with traffic for the telemetry strip
const trafficSite = metrics.sites.find(s => s.traffic !== null);
---

<div class="live-proof" aria-label="Ranking and traffic proof: two sites built with these GEO/SEO techniques">
  <div class="lp-header">
    <span class="lp-title">Live Rankings</span>
    <span class="lp-badge">Verified {verifiedFormatted}</span>
  </div>

  <div class="lp-columns">
    {metrics.sites.map((site) => (
      <div class="lp-column">
        <div class="lp-site-header">
          <a href={site.url} target="_blank" rel="noopener noreferrer" class="lp-site-name" style={`--site-color: ${site.color}`}>
            {site.name}
          </a>
          {site.badge && <span class="lp-this-site">{site.badge}</span>}
        </div>
        <RankingGrid rankings={site.rankings} siteColor={site.color} />
      </div>
    ))}
  </div>

  {trafficSite?.traffic && (
    <TrafficMetrics
      traffic={trafficSite.traffic}
      siteColor={trafficSite.color}
      socialProof={trafficSite.socialProof}
    />
  )}

  <VerifyFooter generatedDate={metrics.generated} />
</div>

<style>
  .live-proof {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
    background: var(--color-background);
    position: relative;
  }

  .lp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .lp-title {
    font-family: var(--font-heading, 'Thicccboi', system-ui, sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .lp-badge {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: 100px;
    background: color-mix(in oklch, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
  }

  .lp-columns {
    display: grid;
    grid-template-columns: 11fr 9fr;
    gap: 0;
  }

  .lp-column {
    padding: 20px;
  }

  .lp-column:first-child {
    border-right: 1px solid var(--color-border);
  }

  .lp-site-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .lp-site-name {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--site-color);
    text-decoration: none;
    border-bottom: 1px dashed var(--site-color);
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .lp-site-name:hover {
      opacity: 0.8;
      color: var(--site-color);
    }
  }

  .lp-this-site {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 6px;
    border-radius: 3px;
    background: color-mix(in oklch, var(--color-primary) 15%, transparent);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .lp-columns {
      grid-template-columns: 1fr;
    }
    .lp-column:first-child {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
  }

  /* Scroll-reveal */
  @media (scripting: enabled) {
    .live-proof:not(.is-visible) {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .live-proof.is-visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-proof {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initLiveProof() {
    document.querySelectorAll('.live-proof:not([data-proof-init])').forEach((el) => {
      (el as HTMLElement).dataset.proofInit = '1';
      let animated = false;

      function animateCounters() {
        if (animated) return;
        animated = true;

        // Rank counters (count down from 50)
        el.querySelectorAll('.lp-rank-value[data-target]').forEach((val) => {
          const target = parseInt((val as HTMLElement).dataset.target || '0', 10);
          if (!target) return;
          let current = 50;
          const interval = setInterval(() => {
            current = Math.max(current - Math.ceil((current - target) / 4), target);
            val.textContent = `#${current}`;
            if (current <= target) {
              clearInterval(interval);
              val.textContent = `#${target}`;
            }
          }, 60);
        });

        // Traffic counters (count up from 0)
        el.querySelectorAll('[data-count-target]').forEach((val) => {
          const target = parseInt((val as HTMLElement).dataset.countTarget || '0', 10);
          if (!target) return;
          const duration = 800;
          const start = performance.now();
          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
            const current = Math.round(eased * target);
            val.textContent = current.toLocaleString();
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animateCounters();
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(el);

      // Fallback: show after 2s if observer doesn't fire
      setTimeout(() => {
        if (!el.classList.contains('is-visible')) {
          el.classList.add('is-visible');
          animateCounters();
        }
      }, 2000);
    });
  }

  initLiveProof();
  document.addEventListener('astro:after-swap', initLiveProof);
</script>
