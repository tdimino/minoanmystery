---
/**
 * EvalTribunal — "Tribunal Chamber" for Evaluation & Safety section.
 * UX-revised: inline judge status row, grouped metrics by category, 50/50 split.
 * Kotharat spec + design skill review: 2026-03-18.
 */
const judges = [
  { name: 'Kimi K2.5', verdict: 'PASS', color: '#00b4d8' },
  { name: 'GPT-5.4', verdict: 'PASS', color: '#10a37f' },
  { name: 'Sonnet 4.6', verdict: 'PASS', color: '#d4a843' },
  { name: 'Qwen3.5', verdict: 'PARTIAL', color: '#e85d04' },
  { name: 'Custom LoRA', verdict: 'PASS', color: '#966a85' },
];

const metricGroups = [
  { category: 'Accuracy', metrics: [
    { name: 'Factual Accuracy', pass: true },
    { name: 'Citation Density', pass: true },
    { name: 'Hallucination Rate', pass: true },
    { name: 'Source Diversity', pass: true },
  ]},
  { category: 'Quality', metrics: [
    { name: 'Coherence', pass: true },
    { name: 'Completeness', pass: true },
    { name: 'Answer Relevancy', pass: true },
    { name: 'Character Consistency', pass: true },
    { name: 'Emotional Awareness', pass: true },
  ]},
  { category: 'Safety', metrics: [
    { name: 'Toxicity Detection', pass: true },
    { name: 'Bias Detection', pass: true },
    { name: 'PII Leakage', pass: true },
    { name: 'Scope Boundaries', pass: true },
    { name: 'Refusal Accuracy', pass: true },
  ]},
  { category: 'Fine-Tuning', metrics: [
    { name: 'Domain Accuracy', pass: true },
    { name: 'Style Fidelity', pass: false },
    { name: 'Concept Detection', pass: true },
  ]},
  { category: 'Performance', metrics: [
    { name: 'Latency (p95)', pass: true },
    { name: 'Cost per Query', pass: true },
    { name: 'Token Efficiency', pass: true },
  ]},
];

const scenarios = [
  { name: 'Harmful content generation', instrument: 'Safety' },
  { name: 'Risk detection & escalation', instrument: 'Safety' },
  { name: 'Hallucinated citation injection', instrument: 'Accuracy' },
  { name: 'PII extraction attempt', instrument: 'Privacy' },
  { name: 'Confidential data exfiltration', instrument: 'Privacy' },
  { name: 'Jailbreak via role-play', instrument: 'Security' },
  { name: 'Prompt injection attack', instrument: 'Security' },
  { name: 'Biased recommendation probe', instrument: 'Fairness' },
  { name: 'Character drift under pressure', instrument: 'Fidelity' },
  { name: 'Out-of-scope request handling', instrument: 'Fidelity' },
  { name: 'Fine-tuned vs base model divergence', instrument: 'Training' },
  { name: 'Adversarial paraphrase consistency', instrument: 'Training' },
];

const counters = [
  { value: 5, label: 'Judge providers' },
  { value: 27, label: 'Safety dimensions' },
  { value: 30, label: 'Adversarial scenarios' },
];
---

<div class="eval-tribunal" aria-label="Evaluation framework: 5 LLM judges, 20 metrics, 30+ adversarial scenarios">
  {/* Header */}
  <div class="et-header">
    <div class="et-header-left">
      <i class="ph ph-scales" aria-hidden="true"></i>
      <span class="et-title">Evaluation Framework</span>
    </div>
    <span class="et-header-badge"><span class="et-hero-count" data-target="27">0</span> dimensions</span>
  </div>

  {/* Judge status row — inline name + verdict */}
  <div class="et-judges" role="group" aria-label="LLM judge verdicts">
    {judges.map((j) => (
      <div class="et-judge" style={`--jc: ${j.color}`}>
        <span class="et-judge-dot" aria-hidden="true"></span>
        <span class="et-judge-name">{j.name}</span>
        <span class={`et-verdict ${j.verdict === 'PASS' ? 'et-pass' : 'et-partial'}`}>
          <i class={`ph ${j.verdict === 'PASS' ? 'ph-check' : 'ph-warning'}`} aria-hidden="true"></i>
          {j.verdict}
        </span>
      </div>
    ))}
  </div>

  {/* Split — Grouped Metrics + Adversarial */}
  <div class="et-split">
    <div class="et-metrics-zone">
      <div class="et-zone-label">
        <i class="ph ph-chart-bar" aria-hidden="true"></i>
        <span>20 Metrics</span>
      </div>
      <div class="et-metric-groups">
        {metricGroups.map((group) => (
          <div class="et-group">
            <span class="et-group-label">{group.category}</span>
            <div class="et-group-metrics">
              {group.metrics.map((m) => (
                <span class={`et-metric ${m.pass ? '' : 'et-metric-warn'}`}>
                  <span class="et-metric-dot" aria-hidden="true"></span>
                  {m.name}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="et-adversarial-zone">
      <div class="et-zone-label">
        <i class="ph ph-shield-warning" aria-hidden="true"></i>
        <span>Adversarial Scenarios</span>
        <span class="et-scenario-count">30+</span>
      </div>
      <div class="et-scenario-list">
        {scenarios.map((s) => (
          <div class="et-scenario">
            <span class="et-s-dot" aria-hidden="true"></span>
            <span class="et-s-name">{s.name}</span>
            <span class="et-s-badge">{s.instrument}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Proof footer */}
  <div class="et-proof">
    {counters.map((c) => (
      <div class="et-counter">
        <span class="et-counter-value" data-target={c.value}>0</span>
        <span class="et-counter-label">{c.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .eval-tribunal {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
    background: var(--color-background-alt);
  }

  /* Header */
  .et-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .et-header-left { display: flex; align-items: center; gap: 8px; }
  .et-header-left i { font-size: 16px; color: var(--color-text-muted); }

  .et-title {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text);
  }

  .et-header-badge {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .et-hero-count {
    font-weight: 800;
    color: var(--color-accent);
    font-size: 14px;
  }

  /* Judges — inline status row */
  .et-judges {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
  }

  .et-judge {
    flex: 1;
    min-width: 120px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-right: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .et-judge:last-child { border-right: none; }
  .et-judge:hover { background: var(--color-background); }

  .et-judge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--jc);
    box-shadow: 0 0 6px var(--jc);
    flex-shrink: 0;
  }

  .et-judge-name {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    flex: 1;
    white-space: nowrap;
  }

  .et-verdict {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }

  .et-verdict i { font-size: 10px; }

  .et-pass {
    background: rgba(45, 212, 127, 0.1);
    color: #2dd47f;
  }

  .et-partial {
    background: rgba(212, 168, 67, 0.1);
    color: #d4a843;
  }

  /* Split — 50/50 */
  .et-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .et-zone-label {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border);
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .et-zone-label i { font-size: 13px; }

  .et-scenario-count {
    margin-left: auto;
    padding: 1px 6px;
    border-radius: 3px;
    background: rgba(150, 106, 133, 0.1);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: 700;
  }

  /* Metrics — grouped by category */
  .et-metrics-zone {
    border-right: 1px solid var(--color-border);
  }

  .et-metric-groups {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .et-group-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 6px;
  }

  .et-group-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .et-metric {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    border-radius: 3px;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    color: var(--color-text);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    transition: border-color 0.2s ease;
  }

  .et-metric:hover { border-color: #2dd47f; }

  .et-metric-warn {
    border-color: rgba(212, 168, 67, 0.3);
    background: rgba(212, 168, 67, 0.05);
  }

  .et-metric-warn:hover { border-color: #d4a843; }

  .et-metric-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #2dd47f;
    flex-shrink: 0;
  }

  .et-metric-warn .et-metric-dot { background: #d4a843; }

  /* Adversarial feed */
  .et-adversarial-zone {}

  .et-scenario-list {
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) transparent;
  }

  .et-scenario {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .et-scenario:last-child { border-bottom: none; }
  .et-scenario:hover { background: var(--color-background); }

  .et-s-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2dd47f;
    flex-shrink: 0;
  }

  .et-s-name {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    color: var(--color-text);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .et-s-badge {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Proof footer */
  .et-proof {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .et-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px;
    border-right: 1px solid var(--color-border);
  }

  .et-counter:last-child { border-right: none; }

  .et-counter-value {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 24px;
    font-weight: 800;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .et-counter-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .et-split { grid-template-columns: 1fr; }
    .et-metrics-zone { border-right: none; border-bottom: 1px solid var(--color-border); }
    .et-judges { flex-direction: column; }
    .et-judge { border-right: none; border-bottom: 1px solid var(--color-border); }
    .et-judge:last-child { border-bottom: none; }
    .et-scenario-list { max-height: 200px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .et-judge, .et-metric, .et-scenario { transition: none; }
  }

  @media (scripting: enabled) {
    .eval-tribunal:not(.is-visible) {
      opacity: 0; transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .eval-tribunal.is-visible {
      opacity: 1; transform: translateY(0);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
  }
</style>

<style is:global>
  .eval-tribunal .et-metric::before,
  .eval-tribunal .et-scenario::before,
  .eval-tribunal .et-judge::before {
    display: none !important;
    content: none !important;
  }
</style>

<script>
  function initEvalTribunal() {
    document.querySelectorAll('.eval-tribunal').forEach((el) => {
      let counted = false;

      function animateCounters() {
        if (counted) return;
        counted = true;
        el.querySelectorAll('.et-counter-value, .et-hero-count').forEach((c) => {
          const target = parseInt((c as HTMLElement).dataset.target || '0', 10);
          let current = 0;
          const step = Math.max(1, Math.floor(target / 20));
          const interval = setInterval(() => {
            current = Math.min(current + step, target);
            c.textContent = String(current);
            if (current >= target) clearInterval(interval);
          }, 30);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animateCounters();
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(el);
      setTimeout(() => { if (!el.classList.contains('is-visible')) { el.classList.add('is-visible'); animateCounters(); } }, 2000);
    });
  }

  initEvalTribunal();
  document.addEventListener('astro:after-swap', initEvalTribunal);
</script>
