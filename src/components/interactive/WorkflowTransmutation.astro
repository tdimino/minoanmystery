---
/**
 * WorkflowTransmutation — Tabbed before/after comparison for AI automation workflows.
 * 4 tabs: Email Triage, Document Processing, Inventory Watch, Content Generation.
 * Each shows manual vs automated with time badges.
 * Replaces proof-ai-automation.jpg.
 */
const workflows = [
  {
    id: 'email',
    label: 'Email Triage',
    icon: 'ph-envelope-simple',
    before: {
      steps: ['Read each email manually', 'Copy to spreadsheet', 'Flag priority by gut feel', 'Route to team via Slack'],
      time: '~15 min',
    },
    after: {
      steps: ['Claude scans inbox via API', 'Classifies priority + intent', 'Routes to correct team channel', 'Drafts response for review'],
      time: '~34 sec',
    },
  },
  {
    id: 'docs',
    label: 'Doc Processing',
    icon: 'ph-file-text',
    before: {
      steps: ['Download PDF attachment', 'Open and read each page', 'Manually extract key fields', 'Enter data into system'],
      time: '~20 min',
    },
    after: {
      steps: ['Pipeline watches inbox folder', 'Extracts fields via structured output', 'Validates against schema', 'Pushes to database + Slack alert'],
      time: '~12 sec',
    },
  },
  {
    id: 'inventory',
    label: 'Inventory Watch',
    icon: 'ph-package',
    before: {
      steps: ['Check supplier websites daily', 'Compare prices in spreadsheet', 'Email team about changes', 'Update internal tracker'],
      time: '~25 min',
    },
    after: {
      steps: ['Scraper runs on schedule', 'Compares against last snapshot', 'Alerts on price/stock changes', 'Auto-updates tracker + log'],
      time: '~45 sec',
    },
  },
  {
    id: 'content',
    label: 'Content Gen',
    icon: 'ph-article',
    before: {
      steps: ['Research topic manually', 'Draft in Google Docs', 'Format for each platform', 'Schedule across 3 channels'],
      time: '~90 min',
    },
    after: {
      steps: ['Claude researches via Exa + RAG', 'Generates draft in brand voice', 'Formats per platform specs', 'Queues via API + notifies'],
      time: '~3 min',
    },
  },
];
---

<div class="workflow-transmute" aria-label="Before and after: manual workflows vs AI automation">
  <div class="wt-tabs" role="tablist">
    {workflows.map((wf, i) => (
      <button
        class={`wt-tab ${i === 0 ? 'active' : ''}`}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`wt-panel-${wf.id}`}
        data-tab={wf.id}
      >
        <i class={`ph ${wf.icon}`} aria-hidden="true"></i>
        <span>{wf.label}</span>
      </button>
    ))}
  </div>

  <div class="wt-panels">
    {workflows.map((wf, i) => (
      <div
        class={`wt-panel ${i === 0 ? 'active' : ''}`}
        id={`wt-panel-${wf.id}`}
        role="tabpanel"
        aria-hidden={i !== 0 ? 'true' : 'false'}
      >
        <div class="wt-split">
          <div class="wt-side wt-before">
            <div class="wt-side-header">
              <span class="wt-side-label">Before</span>
              <span class="wt-time-badge before-badge">{wf.before.time}</span>
            </div>
            <ol class="wt-steps">
              {wf.before.steps.map((step) => (
                <li class="wt-step before-step">
                  <span class="step-connector" aria-hidden="true"></span>
                  <span class="step-text">{step}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="wt-divider" aria-hidden="true">
            <span class="divider-arrow">→</span>
          </div>

          <div class="wt-side wt-after">
            <div class="wt-side-header">
              <span class="wt-side-label">After</span>
              <span class="wt-time-badge after-badge">{wf.after.time}</span>
            </div>
            <ol class="wt-steps">
              {wf.after.steps.map((step) => (
                <li class="wt-step after-step">
                  <span class="step-connector" aria-hidden="true"></span>
                  <span class="step-text">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .workflow-transmute {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
  }

  .wt-tabs {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-background-alt);
    overflow-x: auto;
  }

  .wt-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px 16px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .wt-tab:hover { color: var(--color-text); }

  .wt-tab.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .wt-tab i { font-size: 14px; }

  .wt-panels { position: relative; }

  .wt-panel {
    display: none;
    padding: 24px;
  }

  .wt-panel.active { display: block; }

  .wt-split {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }

  .wt-side { padding: 0 16px; }

  .wt-side-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .wt-side-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .wt-time-badge {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .before-badge {
    background: rgba(234, 67, 53, 0.12);
    color: #ea4335;
  }

  .after-badge {
    background: rgba(45, 212, 127, 0.12);
    color: #2dd47f;
  }

  .wt-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wt-step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text);
    position: relative;
    padding-left: 0;
  }

  .step-connector {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .before-step .step-connector {
    border: 2px dashed var(--color-text-muted);
    background: none;
  }

  .after-step .step-connector {
    background: var(--color-primary);
    box-shadow: 0 0 6px rgba(139, 92, 246, 0.4);
    border: none;
  }

  .wt-before { filter: saturate(0.5); }

  .wt-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 12px;
    align-self: center;
  }

  .divider-arrow {
    font-size: 20px;
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .wt-split {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .wt-divider {
      padding: 8px 0;
    }
    .divider-arrow {
      transform: rotate(90deg);
    }
    .wt-side { padding: 0; }
    .wt-tab { padding: 10px 8px; font-size: 11px; }
    .wt-tab span { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wt-tab { transition: none; }
  }

  @media (scripting: enabled) {
    .workflow-transmute:not(.is-visible) {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .workflow-transmute.is-visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
  }
</style>

<style is:global>
  /* Suppress rich-text li::before bullets inside workflow component */
  .workflow-transmute .wt-step::before {
    display: none !important;
    content: none !important;
  }
</style>

<script>
  function initWorkflowTransmute() {
    document.querySelectorAll('.workflow-transmute').forEach((el) => {
      // Tab switching
      el.querySelectorAll('.wt-tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          const tabId = tab.dataset.tab;

          // Deactivate all tabs and panels
          el.querySelectorAll('.wt-tab').forEach((t) => {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          el.querySelectorAll('.wt-panel').forEach((p) => {
            p.classList.remove('active');
            p.setAttribute('aria-hidden', 'true');
          });

          // Activate clicked tab and panel
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
          const panel = el.querySelector(`#wt-panel-${tabId}`);
          if (panel) {
            panel.classList.add('active');
            panel.setAttribute('aria-hidden', 'false');
          }
        });
      });

      // Keyboard navigation
      const tabs = Array.from(el.querySelectorAll('.wt-tab'));
      tabs.forEach((tab, i) => {
        tab.addEventListener('keydown', (e) => {
          let next = -1;
          if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
          else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
          if (next >= 0) {
            e.preventDefault();
            tabs[next].focus();
            tabs[next].click();
          }
        });
      });

      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(el);
      setTimeout(() => { if (!el.classList.contains('is-visible')) el.classList.add('is-visible'); }, 2000);
    });
  }

  initWorkflowTransmute();
  document.addEventListener('astro:after-swap', initWorkflowTransmute);
</script>
