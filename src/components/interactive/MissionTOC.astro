---
/**
 * MissionTOC — "Operations Manifest" table of contents.
 * Zero-padded numbered entries with Phosphor icons, scroll-spy active state,
 * left-border accent channel, staggered reveal.
 * Kotharat design spec: 2026-03-17.
 */
interface Section {
  num: string;
  icon: string;
  label: string;
  href: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<nav class="mission-toc" aria-label="Table of contents">
  <div class="toc-header">
    <span class="toc-ops">OPS</span>
    <span class="toc-count">{sections.length}</span>
  </div>
  <ol class="toc-list">
    {sections.map((s, i) => (
      <li class="toc-item" style={`--row: ${i}; --row-hue: ${[340, 25, 45, 180, 210, 270, 300, 150, 60][i] ?? 0}`}>
        <a class="toc-link" href={s.href} data-active="false">
          <span class="toc-num">{s.num}</span>
          <i class={`ph ${s.icon} toc-icon`} aria-hidden="true"></i>
          <span class="toc-label" data-text={s.label}>{s.label}</span>
          <span class="toc-cursor" aria-hidden="true"></span>
        </a>
      </li>
    ))}
  </ol>
</nav>

<style>
  .mission-toc {
    margin: 0 0 40px 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-background-alt);
    overflow: hidden;
  }

  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .toc-ops {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .toc-count {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-item {
    margin: 0;
    padding: 0;
    /* Pastel accent — each row gets a unique hue via --row-hue */
    border-left: 3px solid hsl(var(--row-hue, 0), 40%, 78%);
  }

  /* JS hides items before typing; no-JS shows them immediately */
  @media (scripting: enabled) {
    .mission-toc:not(.typed-done) .toc-item {
      opacity: 0;
    }
    .mission-toc:not(.typed-done) .toc-item.typed,
    .mission-toc:not(.typed-done) .toc-item.typing {
      opacity: 1;
    }
  }

  /* Blinking cursor */
  .toc-cursor {
    display: none;
    width: 2px;
    height: 14px;
    background: var(--color-primary);
    margin-left: 2px;
    flex-shrink: 0;
  }

  .toc-item.typing .toc-cursor {
    display: inline-block;
    animation: cursor-blink 0.6s steps(1) infinite;
  }

  @keyframes cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .toc-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px 9px 14px;
    text-decoration: none;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    border-left: none;
    transition: background-color 0.2s ease;
  }

  .toc-link:hover {
    background: rgba(150, 106, 133, 0.04);
  }

  .toc-link:hover .toc-label { color: var(--color-text); }
  .toc-link:hover .toc-num { opacity: 0.7; }
  .toc-link:hover .toc-icon { opacity: 0.7; }

  .toc-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
    border-radius: 0;
  }

  /* Active state via scroll-spy */
  .toc-link[data-active="true"] {
    border-left-color: var(--color-primary);
    background: rgba(150, 106, 133, 0.05);
  }

  .toc-link[data-active="true"] .toc-num {
    color: var(--color-accent);
    opacity: 1;
  }

  .toc-link[data-active="true"] .toc-icon {
    color: var(--color-primary);
    opacity: 0.8;
  }

  .toc-link[data-active="true"] .toc-label {
    color: var(--color-text);
  }

  .toc-num {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    opacity: 0.45;
    min-width: 20px;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .toc-icon {
    font-size: 14px;
    color: var(--color-text-muted);
    opacity: 0.5;
    width: 16px;
    text-align: center;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .toc-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  @media (max-width: 768px) {
    .toc-link { padding: 8px 12px 8px 11px; gap: 8px; }
    .toc-label { font-size: 11px; }
    .toc-header { padding: 8px 12px; }
    .toc-icon { display: none; }
  }

  @media (max-width: 480px) {
    .toc-num { display: none; }
  }

  :global([data-theme='dark']) .toc-item {
    border-left-color: hsl(var(--row-hue, 0), 50%, 55%);
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-item { opacity: 1; }
    .toc-cursor { display: none; }
    .toc-link, .toc-num, .toc-icon, .toc-label { transition-duration: 0.01s; }
  }
</style>

<style is:global>
  /* Suppress rich-text list styles inside MissionTOC */
  .mission-toc .toc-item::before {
    display: none !important;
    content: none !important;
  }

  .mission-toc .toc-list {
    margin-bottom: 0 !important;
    padding-left: 0 !important;
  }

  .mission-toc .toc-item {
    margin-bottom: 0 !important;
    padding-left: 0 !important;
  }

  /* Scroll margin for targeted h2s */
  .rich-text h2[id] {
    scroll-margin-top: 80px;
  }
</style>

<script>
  // Kotharat "Teletype Spool" — scroll-linked character typing.
  // Desktop: scroll position drives character reveal. Mobile: time-based fallback.

  // Eased band mapping (Kotharat spec): early rows faster, later rows slower
  const ROW_BANDS = [
    [0.00, 0.08], [0.08, 0.17], [0.17, 0.27], [0.27, 0.38],
    [0.38, 0.49], [0.49, 0.60], [0.60, 0.72], [0.72, 0.85],
    [0.85, 1.00],
  ];

  const IS_MOBILE = typeof window !== 'undefined' && window.innerWidth < 768;
  const PREFERS_REDUCED = typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initMissionTOC() {
    document.querySelectorAll('.mission-toc').forEach((nav) => {
      if (nav.classList.contains('typed-done') || (nav as any).__tocBound) {
        if (nav.classList.contains('typed-done')) initScrollSpy(nav);
        return;
      }

      if (PREFERS_REDUCED) {
        showAllImmediately(nav as HTMLElement);
        initScrollSpy(nav);
        return;
      }

      (nav as any).__tocBound = true;
      const items = Array.from(nav.querySelectorAll('.toc-item')) as HTMLElement[];
      if (!items.length) { initScrollSpy(nav); return; }

      // Clear labels for JS-driven typing
      items.forEach((item) => {
        const label = item.querySelector('.toc-label') as HTMLElement;
        if (label) label.textContent = '';
      });

      if (IS_MOBILE) {
        // Mobile: time-based typewriter on viewport entry
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              observer.unobserve(entry.target);
              startTimeTypewriter(entry.target as HTMLElement, items);
            }
          });
        }, { threshold: 0.1 });
        observer.observe(nav);
      } else {
        // Desktop: scroll-position-driven typing
        startScrollTyping(nav as HTMLElement, items);
      }

      // 3s fallback
      setTimeout(() => {
        if (!nav.classList.contains('typed-done')) {
          showAllImmediately(nav as HTMLElement);
          initScrollSpy(nav);
        }
      }, 3000);
    });
  }

  function startScrollTyping(nav: HTMLElement, items: HTMLElement[]) {
    let ticking = false;
    let done = false;

    function getProgress(): number {
      const rect = nav.getBoundingClientRect();
      const vh = window.innerHeight;
      // Progress: 0 when TOC bottom enters viewport, 1 when TOC top at 15% from top
      const start = vh;
      const end = vh * 0.15;
      return Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
    }

    function apply(progress: number) {
      if (done) return;
      const rowCount = items.length;

      for (let i = 0; i < rowCount; i++) {
        const item = items[i];
        const label = item.querySelector('.toc-label') as HTMLElement;
        if (!label) continue;
        const fullText = label.dataset.text || '';

        // Use eased bands if available, otherwise equal bands
        const band = ROW_BANDS[i] || [i / rowCount, (i + 1) / rowCount];
        const [bandStart, bandEnd] = band;

        if (progress < bandStart) {
          item.classList.remove('typing', 'typed');
          label.textContent = '';
        } else if (progress >= bandEnd) {
          item.classList.remove('typing');
          item.classList.add('typed');
          label.textContent = fullText;
        } else {
          const rowProgress = (progress - bandStart) / (bandEnd - bandStart);
          item.classList.add('typing');
          item.classList.remove('typed');
          if (rowProgress < 0.08) {
            label.textContent = '';
          } else {
            const charProgress = (rowProgress - 0.08) / 0.92;
            label.textContent = fullText.slice(0, Math.floor(charProgress * fullText.length));
          }
        }
      }

      if (progress >= 1) {
        done = true;
        items.forEach((item) => {
          item.classList.remove('typing');
          item.classList.add('typed');
          const l = item.querySelector('.toc-label') as HTMLElement;
          if (l) l.textContent = l.dataset.text || '';
        });
        nav.classList.add('typed-done');
        window.removeEventListener('scroll', onScroll);
        initScrollSpy(nav);
      }
    }

    function onScroll() {
      if (done) return;
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          apply(getProgress());
          ticking = false;
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    apply(getProgress());
  }

  function startTimeTypewriter(nav: HTMLElement, items: HTMLElement[]) {
    let row = 0;
    function typeRow() {
      if (row >= items.length) {
        nav.classList.add('typed-done');
        initScrollSpy(nav);
        return;
      }
      const item = items[row] as HTMLElement;
      const label = item.querySelector('.toc-label') as HTMLElement;
      const fullText = label?.dataset.text || '';
      item.classList.add('typing');
      label.textContent = '';
      let ci = 0;
      const iv = setInterval(() => {
        if (ci < fullText.length) {
          label.textContent = fullText.slice(0, ++ci);
        } else {
          clearInterval(iv);
          item.classList.remove('typing');
          item.classList.add('typed');
          row++;
          setTimeout(typeRow, 120);
        }
      }, 30);
    }
    typeRow();
  }

  function showAllImmediately(nav: HTMLElement) {
    nav.querySelectorAll('.toc-item').forEach((item) => {
      item.classList.add('typed');
      item.classList.remove('typing');
      const label = item.querySelector('.toc-label') as HTMLElement;
      if (label) label.textContent = label.dataset.text || '';
    });
    nav.classList.add('typed-done');
  }

  function initScrollSpy(nav: Element) {
    const links = Array.from(nav.querySelectorAll('.toc-link'));
    if (!links.length) return;
    const targets: { el: Element; link: HTMLElement }[] = [];
    links.forEach((link) => {
      const href = link.getAttribute('href');
      if (!href) return;
      const id = href.replace('#', '');
      const el = document.getElementById(id);
      if (el) targets.push({ el, link: link as HTMLElement });
    });
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => {
              (l as HTMLElement).setAttribute('data-active', 'false');
              (l as HTMLElement).removeAttribute('aria-current');
            });
            const match = targets.find((t) => t.el === entry.target);
            if (match) {
              match.link.setAttribute('data-active', 'true');
              match.link.setAttribute('aria-current', 'true');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );
    targets.forEach((t) => observer.observe(t.el));
    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  initMissionTOC();
  document.addEventListener('astro:after-swap', initMissionTOC);
</script>
