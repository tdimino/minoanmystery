---
/**
 * GeoCommand — GEO readiness scorecard hero.
 * Generalized (no specific sites). Shows what a client's presence looks like
 * after GEO optimization: 6 platform targets + 4 implementation pillars.
 * Light/dark adaptive. Clean editorial treatment.
 */
const platforms = [
  { label: 'Google', color: '#4285f4', icon: 'ph-magnifying-glass' },
  { label: 'ChatGPT', color: '#10a37f', icon: 'ph-chat-circle-text' },
  { label: 'Perplexity', color: '#6366f1', icon: 'ph-sparkle' },
  { label: 'Bing', color: '#00809d', icon: 'ph-globe' },
  { label: 'Claude', color: '#d4a843', icon: 'ph-brain' },
  { label: 'AI Overview', color: '#ea4335', icon: 'ph-lightning' },
];

const pillars = [
  { label: 'llms.txt', status: 'Machine-readable site index for AI engines', icon: 'ph-file-text', color: '#2dd47f' },
  { label: 'JSON-LD', status: 'Structured data so engines understand what you do', icon: 'ph-brackets-curly', color: '#4285f4' },
  { label: 'AI Crawlers', status: 'Explicit access for 21 AI bots in robots.txt', icon: 'ph-robot', color: '#d4a843' },
  { label: 'robots.txt', status: 'Dual-group config: search engines + AI engines', icon: 'ph-shield-check', color: '#9b59b6' },
];
---

<div class="geo-scorecard">
  <div class="gs-section">
    <div class="gs-section-header">
      <span class="gs-section-label">Where your clients will find you</span>
      <span class="gs-section-count"><span class="gs-count" data-target="6">0</span> platforms</span>
    </div>
    <div class="gs-platforms">
      {platforms.map((p) => (
        <div class="gs-platform" style={`--pc: ${p.color}`}>
          <i class={`ph ${p.icon}`} aria-hidden="true"></i>
          <span class="gs-platform-name">{p.label}</span>
          <span class="gs-platform-dot" aria-hidden="true"></span>
        </div>
      ))}
    </div>
  </div>

  <div class="gs-divider" aria-hidden="true"></div>

  <div class="gs-section">
    <div class="gs-section-header">
      <span class="gs-section-label">What I implement</span>
      <span class="gs-section-count">4 pillars</span>
    </div>
    <div class="gs-pillars">
      {pillars.map((p) => (
        <div class="gs-pillar" style={`--plc: ${p.color}`}>
          <div class="gs-pillar-header">
            <i class={`ph ${p.icon}`} aria-hidden="true"></i>
            <span class="gs-pillar-label">{p.label}</span>
          </div>
          <span class="gs-pillar-desc">{p.status}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .geo-scorecard {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-background);
  }

  .gs-section {
    padding: 20px 24px;
  }

  .gs-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .gs-section-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .gs-section-count {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .gs-count {
    font-weight: 800;
    color: var(--color-primary);
  }

  /* Platforms — horizontal status pills */
  .gs-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gs-platform {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-background-alt);
    transition: border-color 0.2s ease, background 0.2s ease;
    flex: 1;
    min-width: 130px;
  }

  .gs-platform:hover {
    border-color: var(--pc);
    background: color-mix(in srgb, var(--pc) 4%, var(--color-background));
  }

  .gs-platform i {
    font-size: 16px;
    color: var(--pc);
  }

  .gs-platform-name {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text);
    flex: 1;
  }

  .gs-platform-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pc);
    box-shadow: 0 0 6px var(--pc);
    flex-shrink: 0;
  }

  /* Divider */
  .gs-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0 24px;
  }

  /* Pillars — 4 columns */
  .gs-pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .gs-pillar {
    padding: 14px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.2s ease;
    border-left: none;
  }

  .gs-pillar:hover {
    border-color: var(--plc);
  }

  .gs-pillar-header {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .gs-pillar-header i {
    font-size: 14px;
    color: var(--plc);
  }

  .gs-pillar-label {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-text);
  }

  .gs-pillar-desc {
    font-size: 12px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  @media (max-width: 991px) {
    .gs-pillars { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .gs-platforms { flex-direction: column; }
    .gs-platform { min-width: 100%; }
    .gs-pillars { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gs-platform, .gs-pillar { transition: none; }
  }

  @media (scripting: enabled) {
    .geo-scorecard:not(.is-visible) {
      opacity: 0; transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .geo-scorecard.is-visible {
      opacity: 1; transform: translateY(0);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
  }
</style>

<script>
  function initGeoScorecard() {
    document.querySelectorAll('.geo-scorecard').forEach((el) => {
      let counted = false;

      function animateCounter() {
        if (counted) return;
        counted = true;
        el.querySelectorAll('.gs-count').forEach((c) => {
          const target = parseInt((c as HTMLElement).dataset.target || '0', 10);
          let current = 0;
          const interval = setInterval(() => {
            current++;
            c.textContent = String(current);
            if (current >= target) clearInterval(interval);
          }, 120);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animateCounter();
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(el);
      setTimeout(() => { if (!el.classList.contains('is-visible')) { el.classList.add('is-visible'); animateCounter(); } }, 2000);
    });
  }

  initGeoScorecard();
  document.addEventListener('astro:after-swap', initGeoScorecard);
</script>
