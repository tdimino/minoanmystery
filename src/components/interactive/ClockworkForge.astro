---
/**
 * ClockworkForge — AI Automation pipeline hero.
 * Animated data flow from manual inputs through agent to automated outputs.
 * "Amber Scrying Table" — Kotharat design spec.
 */
---

<div class="clockwork-forge" aria-label="Workflow automation pipeline: manual inputs transformed into automated outputs through an AI agent">
  <div class="pipeline-stage inputs">
    <span class="stage-label">Manual inputs</span>
    <div class="input-nodes">
      <div class="node node-email"><i class="ph ph-envelope-simple" aria-hidden="true"></i><span>Email</span></div>
      <div class="node node-spreadsheet"><i class="ph ph-table" aria-hidden="true"></i><span>Spreadsheet</span></div>
      <div class="node node-pdf"><i class="ph ph-file-pdf" aria-hidden="true"></i><span>PDF</span></div>
    </div>
  </div>

  <div class="pipeline-flow">
    <svg class="flow-svg" viewBox="0 0 200 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,30 C60,30 60,80 100,80" class="flow-path path-in" />
      <path d="M0,80 C60,80 60,80 100,80" class="flow-path path-in" />
      <path d="M0,130 C60,130 60,80 100,80" class="flow-path path-in" />
      <path d="M100,80 C140,80 140,30 200,30" class="flow-path path-out" />
      <path d="M100,80 C140,80 140,80 200,80" class="flow-path path-out" />
      <path d="M100,80 C140,80 140,130 200,130" class="flow-path path-out" />
      <path id="mp1" d="M0,30 C60,30 60,80 100,80 C140,80 140,30 200,30" class="hidden-path" />
      <path id="mp2" d="M0,80 C60,80 60,80 100,80 C140,80 140,80 200,80" class="hidden-path" />
      <path id="mp3" d="M0,130 C60,130 60,80 100,80 C140,80 140,130 200,130" class="hidden-path" />
      <circle r="3" class="particle"><animateMotion dur="3s" repeatCount="indefinite"><mpath href="#mp1" /></animateMotion></circle>
      <circle r="3" class="particle"><animateMotion dur="3s" repeatCount="indefinite" begin="0.5s"><mpath href="#mp2" /></animateMotion></circle>
      <circle r="3" class="particle"><animateMotion dur="3s" repeatCount="indefinite" begin="1s"><mpath href="#mp3" /></animateMotion></circle>
    </svg>
    <div class="agent-node">
      <div class="agent-icon"><i class="ph ph-lightning-fill" aria-hidden="true"></i></div>
      <span class="agent-label">Agent</span>
    </div>
  </div>

  <div class="pipeline-stage outputs">
    <span class="stage-label">Automated outputs</span>
    <div class="output-nodes">
      <div class="node node-report"><i class="ph ph-chart-bar" aria-hidden="true"></i><span>Reports</span></div>
      <div class="node node-alert"><i class="ph ph-bell-ringing" aria-hidden="true"></i><span>Alerts</span></div>
      <div class="node node-response"><i class="ph ph-chat-circle-text" aria-hidden="true"></i><span>Responses</span></div>
    </div>
  </div>
</div>

<style>
  .clockwork-forge {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
    min-height: 280px;
    background: var(--color-background-alt);
  }

  .pipeline-stage { padding: 28px 24px; display: flex; flex-direction: column; gap: 16px; }
  .stage-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); }
  .input-nodes, .output-nodes { display: flex; flex-direction: column; gap: 12px; }

  .node {
    display: flex; align-items: center; gap: 10px; padding: 10px 14px;
    border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-background);
    font-size: 13px; font-weight: 600; color: var(--color-text);
    transition: border-color 0.35s ease;
  }

  .node i { font-size: 16px; color: var(--color-text-muted); }
  .inputs .node { border-style: dashed; opacity: 0.75; }
  .outputs .node { border-color: var(--color-primary); border-left: 3px solid var(--color-primary); }
  .outputs .node i { color: var(--color-primary); }

  .pipeline-flow { position: relative; display: flex; align-items: center; justify-content: center; padding: 20px 0; }
  .flow-svg { width: 100%; height: 160px; }

  .flow-path { fill: none; stroke: var(--color-border); stroke-width: 1; stroke-dasharray: 6 4; animation: dash-flow 1.5s linear infinite; }
  .path-out { stroke: var(--color-primary); stroke-dasharray: 8 3; }
  @keyframes dash-flow { to { stroke-dashoffset: -20; } }

  .hidden-path { fill: none; stroke: none; }
  .particle { fill: var(--color-accent); filter: drop-shadow(0 0 4px rgba(212, 175, 55, 0.6)); }

  .agent-node { position: absolute; left: 50%; top: 56%; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; gap: 6px; z-index: 2; }
  .agent-icon {
    width: 44px; height: 44px; border-radius: 50%; background: var(--color-primary);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 20px rgba(150, 106, 133, 0.3); animation: agent-breathe 3s ease-in-out infinite;
  }
  .agent-icon i { font-size: 20px; color: #fff; }
  .agent-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); }
  @keyframes agent-breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); box-shadow: 0 0 30px rgba(150, 106, 133, 0.45); } }

  @media (max-width: 768px) {
    .clockwork-forge { grid-template-columns: 1fr; }
    .input-nodes, .output-nodes { flex-direction: row; flex-wrap: wrap; }
    .node { flex: 1 1 auto; justify-content: center; font-size: 12px; }
    .node span { display: none; }
    .node i { font-size: 20px; }
    .flow-svg { height: 100px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-path { animation: none; }
    .particle { display: none; }
    .agent-icon { animation: none; }
  }

  @media (scripting: enabled) {
    .clockwork-forge { opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .clockwork-forge.is-visible { opacity: 1; transform: translateY(0); }
    .node { opacity: 0; transform: translateX(-12px); transition: opacity 0.4s ease, transform 0.4s ease; }
    .outputs .node { transform: translateX(12px); }
    .node.node-revealed { opacity: 1; transform: translateX(0); }
    .inputs .node.node-revealed { opacity: 0.75; }
  }
</style>

<script>
  function initClockworkForge() {
    document.querySelectorAll('.clockwork-forge').forEach((el) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              const nodes = entry.target.querySelectorAll('.node');
              nodes.forEach((node, i) => {
                setTimeout(() => node.classList.add('node-revealed'), 300 + i * 150);
              });
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(el);
    });
  }

  initClockworkForge();
  document.addEventListener('astro:after-swap', initClockworkForge);
</script>
