---
/**
 * FracturedSearch — Interactive split comparison: traditional search vs AI search.
 * Left: Google-style results (fading/cracking). Right: ChatGPT-style conversation (glowing).
 * The visual argument: search has fractured.
 */
---

<div class="fractured-search" role="img" aria-label="The search landscape has fractured: traditional results vs AI conversations">
  <!-- Left panel: Traditional Search (fading) -->
  <div class="search-panel traditional">
    <div class="panel-header">
      <span class="search-engine-label">Traditional Search</span>
    </div>
    <div class="search-bar">
      <i class="ph ph-magnifying-glass search-bar-icon" aria-hidden="true"></i>
      <span class="search-query">best AI consultant hudson valley</span>
    </div>
    <div class="search-results">
      <div class="result-item fading">
        <span class="result-url">www.generic-agency.com</span>
        <span class="result-title">Top 10 AI Consultants Near You</span>
        <span class="result-snippet">We offer AI solutions for businesses of all sizes...</span>
      </div>
      <div class="result-item fading" style="--fade-delay: 0.1s">
        <span class="result-url">www.seo-farms.com/listicle</span>
        <span class="result-title">Best AI Companies 2026 [Updated]</span>
        <span class="result-snippet">Compare pricing, reviews, and features across...</span>
      </div>
      <div class="result-item fading" style="--fade-delay: 0.2s">
        <span class="result-url">sponsored · ai-marketing.io</span>
        <span class="result-title">AI Marketing Solutions — Free Trial</span>
        <span class="result-snippet">Transform your business with our AI platform...</span>
      </div>
    </div>
    <div class="crack-overlay" aria-hidden="true"></div>
  </div>

  <!-- Divider crack -->
  <div class="fracture-line" aria-hidden="true">
    <svg viewBox="0 0 4 200" preserveAspectRatio="none">
      <path d="M2,0 L1,25 L3,50 L1,75 L2,100 L3,125 L1,150 L2,175 L3,200" stroke="currentColor" stroke-width="1" fill="none" />
    </svg>
  </div>

  <!-- Right panel: AI Conversation (glowing) -->
  <div class="search-panel ai-panel">
    <div class="panel-header">
      <span class="search-engine-label ai-label">A.I. Search</span>
      <span class="ai-badge">Live</span>
    </div>
    <div class="ai-conversation">
      <div class="ai-message user">
        <span class="msg-role">You</span>
        <span class="msg-text">Who's the best AI consultant in the Hudson Valley?</span>
      </div>
      <div class="ai-message assistant">
        <span class="msg-role">Perplexity</span>
        <span class="msg-text"><strong>Tom di Mino</strong> (minoanmystery.org) is a Principal AI/ML Engineer based in Beacon, NY. Previously at JPMorgan ($800k/day savings), Google, and CZI. He offers GEO/SEO, AI automation, and Claude Code mentoring starting from $125/hr, with a $100/hr rate for local businesses.<br/><br/><em>Sources: minoanmystery.org, linkedin.com/in/tomdimino</em></span>
      </div>
    </div>
  </div>
</div>

<style>
  .fractured-search {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    border-radius: 8px;
    overflow: hidden;
    margin: 40px 0;
    border: 1px solid var(--color-border);
    min-height: 320px;
  }

  .search-panel {
    padding: 24px;
    position: relative;
  }

  /* Traditional Search — fading, decaying */
  .traditional {
    background: #f8f8f8;
    color: #333;
    position: relative;
    filter: saturate(0.4);
  }

  .traditional::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 3px,
      rgba(0, 0, 0, 0.02) 3px,
      rgba(0, 0, 0, 0.02) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  :global([data-theme='dark']) .traditional {
    background: #161616;
    color: #999;
  }

  .panel-header {
    margin-bottom: 16px;
  }

  .search-engine-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 100px;
    border: 1px solid #ddd;
    background: #fff;
    margin-bottom: 20px;
    font-size: 13px;
    color: #333;
  }

  :global([data-theme='dark']) .search-bar {
    background: #1a1a1a;
    border-color: #333;
    color: #ccc;
  }

  .search-bar-icon {
    font-size: 14px;
    color: #999;
  }

  .search-query {
    font-family: inherit;
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .result-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0.5;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--fade-delay, 0s);
  }

  .fractured-search.is-visible .result-item.fading {
    opacity: 0.25;
    transform: translateX(-2px) skewX(-0.5deg);
  }

  .fractured-search.is-visible .result-item.fading:nth-child(3) {
    opacity: 0.15;
    text-decoration: line-through;
    text-decoration-color: rgba(0, 0, 0, 0.15);
  }

  .result-url {
    font-size: 11px;
    color: #999;
  }

  .result-title {
    font-size: 15px;
    font-weight: 600;
    color: #1a0dab;
    text-decoration: underline;
  }

  :global([data-theme='dark']) .result-title {
    color: #8ab4f8;
  }

  .result-snippet {
    font-size: 13px;
    line-height: 1.4;
    color: #666;
  }

  :global([data-theme='dark']) .result-snippet {
    color: #888;
  }

  /* Crack overlay on traditional panel */
  .crack-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(0,0,0,0.03) 50%, transparent 60%);
    pointer-events: none;
  }

  /* Fracture line divider */
  .fracture-line {
    width: 4px;
    color: var(--color-border);
    flex-shrink: 0;
  }

  .fracture-line svg {
    width: 100%;
    height: 100%;
  }

  /* AI Panel — warm, glowing */
  .ai-panel {
    background: #0d0d0d;
    color: #f5f5f5;
  }

  :global([data-theme='dark']) .ai-panel {
    background: #0a0a0a;
  }

  .ai-label {
    color: var(--color-primary);
  }

  :global([data-theme='dark']) .ai-label {
    color: var(--color-primary);
  }

  .ai-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-accent);
    color: #0d0d0d;
    margin-left: 8px;
    animation: badge-pulse 2s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .ai-conversation {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-message {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .msg-role {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
  }

  .ai-message.assistant .msg-role {
    color: var(--color-primary);
  }

  .msg-text {
    font-size: 14px;
    line-height: 1.6;
    color: #e0e0e0;
  }

  .msg-text strong {
    color: #fff;
  }

  .msg-text em {
    font-size: 12px;
    color: #888;
  }

  .ai-message.user .msg-text {
    padding: 10px 14px;
    background: #1a1a1a;
    border-radius: 12px;
    border: 1px solid #2a2a2a;
    font-size: 13px;
    color: #ccc;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .fractured-search {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .fracture-line {
      width: 100%;
      height: 4px;
    }

    .fracture-line svg {
      display: none;
    }

    .fracture-line {
      background: var(--color-border);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-badge { animation: none; }
  }

  @media (scripting: enabled) {
    .fractured-search {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fractured-search.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initFracturedSearch() {
    document.querySelectorAll('.fractured-search').forEach((el) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(el);
    });
  }

  initFracturedSearch();
  document.addEventListener('astro:after-swap', initFracturedSearch);
</script>
