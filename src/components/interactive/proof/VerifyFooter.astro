---
/**
 * VerifyFooter — Methodology attribution with date stamp.
 */
interface Props {
  generatedDate: string;
}

const { generatedDate } = Astro.props;
const date = new Date(generatedDate);
const formatted = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<div class="lp-footer">
  <span>Rankings verified {formatted}. Traffic from Cloudflare Analytics.</span>
</div>

<style>
  .lp-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--color-border);
  }

  .lp-footer span {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 10px;
    color: var(--color-text-muted);
    opacity: 0.7;
    letter-spacing: 0.02em;
  }
</style>
