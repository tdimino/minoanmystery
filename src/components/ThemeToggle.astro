---
/**
 * ThemeToggle - Soul-aware theme toggle
 *
 * Soul Pattern: Perceive click → Update memory → Dispatch theme change
 *
 * Three-way cycle: dark → light → sunny → dark
 * Sunny mode technique by @danywander (dany.works)
 *
 * Features:
 * - Moon/Sun/SunHorizon icon transition
 * - Keyboard shortcut: Cmd+Shift+D / Ctrl+Shift+D
 * - Works with View Transitions (astro:after-swap)
 */
---

<button
  class="theme-toggle"
  aria-label="Cycle theme"
  title="Cycle theme (Cmd+Shift+D)"
>
  <!-- Phosphor Moon fill (shown in light — next: dark) -->
  <span class="theme-icon theme-icon--moon">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M235.54,150.21a104.84,104.84,0,0,1-37,52.91A104,104,0,0,1,32,120,103.09,103.09,0,0,1,52.88,57.48a104.84,104.84,0,0,1,52.91-37,8,8,0,0,1,10,10,88.08,88.08,0,0,0,109.8,109.8,8,8,0,0,1,10,10Z"/></svg>
  </span>

  <!-- Phosphor Sun fill (shown in dark — next: light) -->
  <span class="theme-icon theme-icon--sun">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm8,24a64,64,0,1,0,64,64A64.07,64.07,0,0,0,128,64ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"/></svg>
  </span>

  <!-- Phosphor SunHorizon fill (shown in sunny — next: dark) -->
  <span class="theme-icon theme-icon--sunhorizon">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor"><path d="M248,160a8,8,0,0,1-8,8H16a8,8,0,0,1,0-16H56.45a73.54,73.54,0,0,1-.45-8,72,72,0,0,1,144,0,73.54,73.54,0,0,1-.45,8H240A8,8,0,0,1,248,160Zm-40,32H48a8,8,0,0,0,0,16H208a8,8,0,0,0,0-16ZM80.84,59.58a8,8,0,0,0,14.32-7.16l-8-16a8,8,0,0,0-14.32,7.16ZM20.42,103.16l16,8a8,8,0,1,0,7.16-14.31l-16-8a8,8,0,1,0-7.16,14.31ZM216,112a8,8,0,0,0,3.57-.84l16-8a8,8,0,1,0-7.16-14.31l-16,8A8,8,0,0,0,216,112ZM164.42,63.16a8,8,0,0,0,10.74-3.58l8-16a8,8,0,0,0-14.32-7.16l-8,16A8,8,0,0,0,164.42,63.16Z"/></svg>
  </span>
</button>

<style>
  .theme-toggle {
    position: relative;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
    color: var(--color-text);
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    transform: scale(1.05);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .theme-icon {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Default (light mode): show moon (next → dark) */
  .theme-icon--moon {
    opacity: 1;
    transform: rotate(0) scale(1);
  }

  .theme-icon--sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.8);
  }

  .theme-icon--sunhorizon {
    opacity: 0;
    transform: rotate(90deg) scale(0.8);
  }

  /* Dark mode: show sun (next → light) */
  :global([data-theme="dark"]) .theme-icon--moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.8);
  }

  :global([data-theme="dark"]) .theme-icon--sun {
    opacity: 1;
    transform: rotate(0) scale(1);
  }

  :global([data-theme="dark"]) .theme-icon--sunhorizon {
    opacity: 0;
    transform: rotate(90deg) scale(0.8);
  }

  /* Sunny mode: show sunhorizon (next → dark) */
  :global([data-theme="sunny"]) .theme-icon--moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.8);
  }

  :global([data-theme="sunny"]) .theme-icon--sun {
    opacity: 0;
    transform: rotate(-90deg) scale(0.8);
  }

  :global([data-theme="sunny"]) .theme-icon--sunhorizon {
    opacity: 1;
    transform: rotate(0) scale(1);
  }

  /* Mobile adjustments - maintain 44px touch target */
  @media (max-width: 767px) {
    .theme-toggle {
      /* Keep 44px for WCAG 2.2 / Apple HIG touch target */
      width: 44px;
      height: 44px;
    }

    .theme-toggle svg {
      width: 18px;
      height: 18px;
    }
  }

  /* Touch feedback */
  .theme-toggle:active {
    transform: scale(0.95);
  }
</style>

<script>
  /**
   * ThemeToggle Controller
   *
   * Three-way cycle: dark → light → sunny → dark
   * Handles theme switching with proper View Transition cleanup.
   * Uses data attribute tracking to prevent duplicate click handlers
   * and tracks the keydown listener for cleanup.
   */
  (function() {
    let keydownHandler: ((e: KeyboardEvent) => void) | null = null;
    let initialized = false;

    const CYCLE: Record<string, string> = { dark: 'light', light: 'sunny', sunny: 'dark' };
    const ARIA: Record<string, string> = {
      dark: 'Theme: dark. Press to switch to light.',
      light: 'Theme: light. Press to switch to sunny.',
      sunny: 'Theme: sunny. Press to switch to dark.',
    };

    function updateAriaLabels(theme: string) {
      document.querySelectorAll('.theme-toggle').forEach((btn) => {
        btn.setAttribute('aria-label', ARIA[theme] || ARIA.light);
      });
    }

    function cycleTheme() {
      const current = document.documentElement.getAttribute('data-theme') || 'light';
      const next = CYCLE[current] ?? 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateAriaLabels(next);
    }

    function initThemeToggles() {
      // Prevent multiple initializations of the keydown handler
      if (!initialized) {
        initialized = true;

        // Keyboard shortcut: Cmd+Shift+D / Ctrl+Shift+D (tracked for cleanup)
        keydownHandler = (e: KeyboardEvent) => {
          if ((e.metaKey || e.ctrlKey) && e.shiftKey && e.key.toLowerCase() === 'd') {
            e.preventDefault();
            cycleTheme();
          }
        };
        document.addEventListener('keydown', keydownHandler);
      }

      // Use data attribute to track initialized toggle buttons
      // (prevents duplicate click handlers on new elements)
      document.querySelectorAll('.theme-toggle').forEach((toggle) => {
        if (!toggle.hasAttribute('data-theme-initialized')) {
          toggle.setAttribute('data-theme-initialized', 'true');
          toggle.addEventListener('click', cycleTheme);
        }
      });

      // Set initial aria-label
      updateAriaLabels(document.documentElement.getAttribute('data-theme') || 'light');
    }

    function cleanupThemeToggles() {
      // Remove keydown listener
      if (keydownHandler) {
        document.removeEventListener('keydown', keydownHandler);
        keydownHandler = null;
      }
      initialized = false;

      // Note: Click handlers on toggle buttons will be cleaned up when
      // elements are replaced during View Transitions
    }

    // Initialize
    initThemeToggles();

    // Cleanup before View Transition swap
    document.addEventListener('astro:before-swap', cleanupThemeToggles);

    // Re-initialize after View Transitions
    document.addEventListener('astro:after-swap', initThemeToggles);
  })();
</script>
